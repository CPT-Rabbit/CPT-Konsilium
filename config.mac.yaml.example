# Mac Docker Desktop example. Secrets stay in ~/konsilium/secrets/konsilium.env.

model:
  provider: custom
  model: "workers-ai/@cf/google/gemma-4-26b-a4b-it"
  base_url: "https://gateway.ai.cloudflare.com/v1/<acct>/<gw>/compat"
  api_key_env: CF_AIG_TOKEN
  request_timeout_s: 120.0
  stream: true

  # Subscription backends are config-only switches:
  # provider: codex
  # model: "gpt-5"
  #
  # provider: claude-cli
  # model: "sonnet"

memory:
  root: /memory
  collection: konsilium_memory

runtime:
  patient_root: /memory
  allow_real_patient_docs: false

deidentification:
  ollama_url: "http://host.docker.internal:11434"
  ollama_model: "gemma3:4b"
  timeout_s: 300.0
  chunk_size: 900
  chunk_overlap: 150
  residue:
    CORRUPTED_TOKEN: block
    DOB: block
    PERSON_HEADER: block
    STREET: block
    PLZ_CITY: block
    PHONE: block
    DIGIT_RUN: block
    KVNR: block
    CASE_NUMBER: block

auth:
  file_env: KONSILIUM_AUTH_FILE
  default_path: /auth/auth.json
